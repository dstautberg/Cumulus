# gRPC server address
SERVER_IP=127.0.0.1
SERVER_PORT=50051

# Directory to back up (leave blank to disable backup)
BACKUP_DIR=/path/to/backup

# Directory to restore files into (leave blank to disable restore)
RESTORE_DIR=/path/to/restore

# How often to run backup and restore cycles (in minutes)
BACKUP_INTERVAL_MINUTES=15

# Number of days to retain downloaded chunks on the server
CHUNK_RETENTION_DAYS=30
